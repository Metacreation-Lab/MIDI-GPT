# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# ── Weights & Biases ──────────────────────────────────────────────────────────
WANDB_API_KEY=your_wandb_api_key_here
WANDB_ENTITY=your_wandb_username_or_team

# ── Cache ─────────────────────────────────────────────────────────────────────
# Root directory for valid-index cache files (default: ~/.midigpt)
# MIDIGPT_CACHE=/scratch/$USER/MIDI-GPT/.midigpt

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Needed if downloading private datasets or to avoid rate limits
# HF_TOKEN=your_huggingface_token_here
